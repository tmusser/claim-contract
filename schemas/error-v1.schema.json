{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tmusser/claim-contract/blob/main/schemas/error-v1.schema.json",
  "title": "claim-contract error v1",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "tool",
    "error",
    "scientific_validation",
    "scope_notice",
    "not_evaluated"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "type": {
      "const": "claim_contract.error"
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "claim-contract"},
        "version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "scientific_validation": {
      "const": false
    },
    "scope_notice": {
      "type": "string",
      "minLength": 1,
      "pattern": "not scientific validation"
    },
    "not_evaluated": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
